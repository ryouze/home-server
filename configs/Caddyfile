# /srv/caddy/conf/Caddyfile

# Global settings
{
    # Disable the admin API (this also disables `caddy reload`)
    admin off

    # Disable automatic HTTPS
    auto_https off
}

# Listen on HTTP port 80
:80 {
    # Redirect bare app paths to their canonical trailing-slash or admin paths
    redir /qbt /qbt/ 308
    redir /pihole /pihole/admin/ 308
    redir /pihole/ /pihole/admin/ 308
    redir /sonarr /sonarr/ 308
    redir /radarr /radarr/ 308
    redir /bazarr /bazarr/ 308
    redir /jellyfin /jellyfin/ 308
    redir /prowlarr /prowlarr/ 308
    redir /filebrowser /filebrowser/ 308

    # Proxy qBittorrent requests and strip `/qbt`
    handle_path /qbt/* {
        reverse_proxy qbittorrent:8080 {
            # Send the backend address as the upstream Host header
            header_up Host {upstream_hostport}
        }
    }

    # Proxy Pi-hole requests and strip `/pihole`
    handle_path /pihole/* {
        reverse_proxy pihole:80
    }

    # Proxy Sonarr requests without stripping `/sonarr`
    # This must match Sonarr's URL Base setting
    handle /sonarr/* {
        reverse_proxy sonarr:8989
    }

    # Proxy Radarr requests without stripping `/radarr`
    # This must match Radarr's URL Base setting
    handle /radarr/* {
        reverse_proxy radarr:7878
    }

    # Proxy Bazarr requests without stripping `/bazarr`
    # This must match Bazarr's URL Base setting
    handle /bazarr/* {
        reverse_proxy bazarr:6767
    }

    # Proxy Jellyfin requests without stripping `/jellyfin`
    # This must match Jellyfin's Base URL setting
    handle /jellyfin/* {
        reverse_proxy jellyfin:8096
    }

    # Proxy Prowlarr requests without stripping `/prowlarr`
    # This must match Prowlarr's URL Base setting
    handle /prowlarr/* {
        reverse_proxy prowlarr:9696
    }

    # Proxy File Browser requests and strip `/filebrowser`
    handle_path /filebrowser/* {
        reverse_proxy filebrowser:80
    }

    # Proxy all remaining requests to Dashy
    handle {
        reverse_proxy dashy:8080
    }
}
